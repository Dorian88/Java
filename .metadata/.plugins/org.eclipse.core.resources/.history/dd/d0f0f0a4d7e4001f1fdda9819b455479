
public class C4Libro {
	
	public C4Libro (String titulo, String autor, int isbn) {
		
		this.titulo = titulo;
		this.autor = autor;
		this.isbn = isbn;
	}
	
	public String getDatos() {
		
		return "El titulo es: " + titulo + ". El autor es: " +  autor + ". Y el ISBN es: " + isbn + "." ;
	}
	
	private String titulo, autor;
	private int isbn;

}
